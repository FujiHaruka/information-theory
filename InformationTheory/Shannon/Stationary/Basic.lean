import Mathlib.Dynamics.Ergodic.Ergodic
import Mathlib.Dynamics.Ergodic.MeasurePreserving
import Mathlib.Probability.IdentDistrib
import Mathlib.MeasureTheory.MeasurableSpace.Basic

/-!
# Stationary processes

Lean encoding of a stationary (resp. ergodic) discrete-time process via a
`MeasurePreserving` (resp. `Ergodic`) shift `T : Œ© ‚Üí Œ©` together with a
single observable `X : Œ© ‚Üí Œ±`. Time-`i` observation is `X ‚àò T^[i]`, the
block `(X_0, ‚Ä¶, X_{n-1})` is `blockRV n : Œ© ‚Üí (Fin n ‚Üí Œ±)`.

These definitions are the foundation for the entropy rate, Birkhoff's ergodic
theorem, the log-likelihood chain rule, and the Shannon‚ÄìMcMillan‚ÄìBreiman
theorem.

## Main definitions

* `StationaryProcess` ‚Äî bundles `T`, `X`, `MeasurePreserving T Œº Œº`, `Measurable X`.
* `StationaryProcess.obs i` ‚Äî the time-`i` observation `X ‚àò T^[i]`.
* `StationaryProcess.blockRV n` ‚Äî joint `(X_0, ‚Ä¶, X_{n-1}) : Œ© ‚Üí (Fin n ‚Üí Œ±)`.
* `ErgodicProcess` ‚Äî extends `StationaryProcess` with `Ergodic T Œº`.

## Main results

* `StationaryProcess.measurable_obs` ‚Äî each `obs i` is measurable.
* `StationaryProcess.measurable_blockRV` ‚Äî `blockRV n` is measurable.
* `StationaryProcess.identDistrib_obs_zero` ‚Äî `obs i` has the same law as `obs 0`
  (stationarity, derived from `MeasurePreserving.iterate`).
-/

namespace InformationTheory.Shannon

open MeasureTheory ProbabilityTheory

variable {Œ© : Type*} [MeasurableSpace Œ©]
variable {Œ± : Type*} [Fintype Œ±] [DecidableEq Œ±] [Nonempty Œ±]
  [MeasurableSpace Œ±] [MeasurableSingletonClass Œ±]

/-- A stationary process: a measure-preserving transformation `T : Œ© ‚Üí Œ©` on
`(Œ©, Œº)` together with a measurable observable `X : Œ© ‚Üí Œ±`. The time-`i`
observation is `X ‚àò T^[i]`. -/
structure StationaryProcess (Œº : Measure Œ©) (Œ± : Type*) [MeasurableSpace Œ±] where
  /-- The shift / time-evolution map. -/
  T : Œ© ‚Üí Œ©
  /-- The single observable; later samples are obtained by composing with `T^[i]`. -/
  X : Œ© ‚Üí Œ±
  /-- `T` preserves `Œº`. -/
  measurePreserving : MeasurePreserving T Œº Œº
  /-- The observable is measurable. -/
  measurable_X : Measurable X

namespace StationaryProcess

omit [Fintype Œ±] [DecidableEq Œ±] [Nonempty Œ±] [MeasurableSingletonClass Œ±]

variable {Œº : Measure Œ©}

/-- Time-`i` observation `X_i := X ‚àò T^[i]`. -/
def obs (p : StationaryProcess Œº Œ±) (i : ‚Ñï) : Œ© ‚Üí Œ± :=
  p.X ‚àò p.T^[i]

/-- The shift map is measurable (it preserves `Œº`, in particular it is measurable). -/
lemma measurable_T (p : StationaryProcess Œº Œ±) : Measurable p.T :=
  p.measurePreserving.measurable

/-- `T^[i]` is measurable for any `i`. -/
lemma measurable_iterate (p : StationaryProcess Œº Œ±) (i : ‚Ñï) : Measurable (p.T^[i]) :=
  (p.measurePreserving.iterate i).measurable

/-- Each time-`i` observation is measurable. -/
lemma measurable_obs (p : StationaryProcess Œº Œ±) (i : ‚Ñï) : Measurable (p.obs i) :=
  p.measurable_X.comp (p.measurable_iterate i)

/-- Block joint observation `(X_0, X_1, ‚Ä¶, X_{n-1}) : Œ© ‚Üí (Fin n ‚Üí Œ±)`. -/
def blockRV (p : StationaryProcess Œº Œ±) (n : ‚Ñï) : Œ© ‚Üí (Fin n ‚Üí Œ±) :=
  fun œâ i ‚Ü¶ p.obs i œâ

/-- The block random variable is measurable. -/
lemma measurable_blockRV (p : StationaryProcess Œº Œ±) (n : ‚Ñï) :
    Measurable (p.blockRV n) := by
  refine measurable_pi_iff.mpr (fun i ‚Ü¶ ?_)
  exact p.measurable_obs i

end StationaryProcess

/-- An ergodic stationary process: a `StationaryProcess` whose shift is moreover
ergodic. The `toStationaryProcess` coercion is auto-generated by `extends`. -/
structure ErgodicProcess (Œº : Measure Œ©) (Œ± : Type*) [MeasurableSpace Œ±]
    extends StationaryProcess Œº Œ± where
  /-- `T` is ergodic for `Œº`. -/
  ergodic : Ergodic T Œº

end InformationTheory.Shannon
