import Mathlib.Dynamics.Ergodic.Ergodic
import Mathlib.Dynamics.Ergodic.MeasurePreserving
import Mathlib.Probability.IdentDistrib
import Mathlib.MeasureTheory.MeasurableSpace.Basic

/-!
# Stationary processes (E-8 / SMB Phase A ‚ÄĒ MVP)

Lean encoding of a stationary (resp. ergodic) discrete-time process via a
`MeasurePreserving` (resp. `Ergodic`) shift `T : ő© ‚Üí ő©` together with a
single observable `X : ő© ‚Üí őĪ`. Time-`i` observation is `X ‚ąė T^[i]`, the
block `(X_0, ‚Ä¶, X_{n-1})` is `blockRV n : ő© ‚Üí (Fin n ‚Üí őĪ)`.

This is the Phase A skeleton from
[`docs/shannon/shannon-mcmillan-breiman-plan.md`](../../docs/shannon/shannon-mcmillan-breiman-plan.md);
the further phases (B onward) build the entropy rate, Birkhoff, log-likelihood
chain rule, and the SMB main theorem on top of these definitions.

## Main definitions

* `StationaryProcess` ‚ÄĒ bundles `T`, `X`, `MeasurePreserving T őľ őľ`, `Measurable X`.
* `StationaryProcess.obs i` ‚ÄĒ the time-`i` observation `X ‚ąė T^[i]`.
* `StationaryProcess.blockRV n` ‚ÄĒ joint `(X_0, ‚Ä¶, X_{n-1}) : ő© ‚Üí (Fin n ‚Üí őĪ)`.
* `ErgodicProcess` ‚ÄĒ extends `StationaryProcess` with `Ergodic T őľ`.

## Main results (Phase A)

* `StationaryProcess.measurable_obs` ‚ÄĒ each `obs i` is measurable.
* `StationaryProcess.measurable_blockRV` ‚ÄĒ `blockRV n` is measurable.
* `StationaryProcess.identDistrib_obs_zero` ‚ÄĒ `obs i` has the same law as `obs 0`
  (stationarity, derived from `MeasurePreserving.iterate`).
-/

namespace InformationTheory.Shannon

open MeasureTheory ProbabilityTheory

variable {ő© : Type*} [MeasurableSpace ő©]
variable {őĪ : Type*} [Fintype őĪ] [DecidableEq őĪ] [Nonempty őĪ]
  [MeasurableSpace őĪ] [MeasurableSingletonClass őĪ]

/-- A stationary process: a measure-preserving transformation `T : ő© ‚Üí ő©` on
`(ő©, őľ)` together with a measurable observable `X : ő© ‚Üí őĪ`. The time-`i`
observation is `X ‚ąė T^[i]`. -/
structure StationaryProcess (őľ : Measure ő©) (őĪ : Type*) [MeasurableSpace őĪ] where
  /-- The shift / time-evolution map. -/
  T : ő© ‚Üí ő©
  /-- The single observable; later samples are obtained by composing with `T^[i]`. -/
  X : ő© ‚Üí őĪ
  /-- `T` preserves `őľ`. -/
  measurePreserving : MeasurePreserving T őľ őľ
  /-- The observable is measurable. -/
  measurable_X : Measurable X

namespace StationaryProcess

omit [Fintype őĪ] [DecidableEq őĪ] [Nonempty őĪ] [MeasurableSingletonClass őĪ]

variable {őľ : Measure ő©}

/-- Time-`i` observation `X_i := X ‚ąė T^[i]`. -/
def obs (p : StationaryProcess őľ őĪ) (i : ‚Ąē) : ő© ‚Üí őĪ :=
  p.X ‚ąė p.T^[i]

/-- The shift map is measurable (it preserves `őľ`, in particular it is measurable). -/
lemma measurable_T (p : StationaryProcess őľ őĪ) : Measurable p.T :=
  p.measurePreserving.measurable

/-- `T^[i]` is measurable for any `i`. -/
lemma measurable_iterate (p : StationaryProcess őľ őĪ) (i : ‚Ąē) : Measurable (p.T^[i]) :=
  (p.measurePreserving.iterate i).measurable

/-- Each time-`i` observation is measurable. -/
lemma measurable_obs (p : StationaryProcess őľ őĪ) (i : ‚Ąē) : Measurable (p.obs i) :=
  p.measurable_X.comp (p.measurable_iterate i)

/-- Block joint observation `(X_0, X_1, ‚Ä¶, X_{n-1}) : ő© ‚Üí (Fin n ‚Üí őĪ)`. -/
def blockRV (p : StationaryProcess őľ őĪ) (n : ‚Ąē) : ő© ‚Üí (Fin n ‚Üí őĪ) :=
  fun ŌČ i => p.obs i ŌČ

/-- The block random variable is measurable. -/
lemma measurable_blockRV (p : StationaryProcess őľ őĪ) (n : ‚Ąē) :
    Measurable (p.blockRV n) := by
  refine measurable_pi_iff.mpr (fun i => ?_)
  exact p.measurable_obs i

end StationaryProcess

/-- An ergodic stationary process: a `StationaryProcess` whose shift is moreover
ergodic. The `toStationaryProcess` coercion is auto-generated by `extends`. -/
structure ErgodicProcess (őľ : Measure ő©) (őĪ : Type*) [MeasurableSpace őĪ]
    extends StationaryProcess őľ őĪ where
  /-- `T` is ergodic for `őľ`. -/
  ergodic : Ergodic T őľ

end InformationTheory.Shannon
