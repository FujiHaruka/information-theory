/-
第4問 (リーグ戦の確率)

  リーグ戦設定:
  - A は他選手に勝つ確率 2/3。
  - A 以外の 2 人の対戦は確率 1/2 ずつ。
  - 引き分けなし、勝ち数最多が優勝、同数なら抽選で 1/n 公平選択。

  (1) 3 人リーグ (A, B, C):
    (i) A が 2 勝 0 敗で優勝の確率 = (2/3)^2 = 4/9。
    (ii) A が 1 勝 1 敗で優勝の確率 = 2 · (2/3)(1/3)(1/2) · (1/3) = 2/27。
    A 優勝確率 = 4/9 + 2/27 = 14/27。

  (2) 4 人リーグ (A, B, C, D):
    全敗者ありで A が 2 勝 1 敗で優勝 = 1/27。
    全敗者なしで A が 2 勝 1 敗で優勝 = 1/9。
    A が 2 勝 1 敗で優勝の合計 = 4/27。
    A が 3 勝 0 敗の確率 = 8/27。
    A 優勝確率 = 8/27 + 4/27 = 12/27 = 4/9。

  (3) 比較: 14/27 - 12/27 = 2/27 > 0。3 人の方が大きい。
-/

import Mathlib.Data.Real.Basic
import Mathlib.Tactic.Linarith
import Mathlib.Tactic.Ring

namespace Common2026.Q4

namespace three_people

/-- (i) A が 2 勝 0 敗で優勝の確率 = (2/3)^2 = 4/9。 -/
theorem A_2win_0loss : ((2 : ℝ)/3) * (2/3) = 4/9 := by norm_num

/-- (ii) A が 1 勝 1 敗で優勝の確率:
    (対戦結果の確率 1/9) × (抽選 1/3) × (A 勝相手 B/C の 2 通り) = 2/27。 -/
theorem A_1win_1loss : 2 * ((2 : ℝ)/3) * (1/3) * (1/2) * (1/3) = 2/27 := by norm_num

/-- A の優勝確率 = 4/9 + 2/27 = 14/27。 -/
theorem A_total : ((4 : ℝ)/9) + 2/27 = 14/27 := by norm_num

end three_people

namespace four_people

/-- D が全敗する確率 = (2/3)(1/2)(1/2) = 1/6。 -/
theorem D_all_loss : ((2 : ℝ)/3) * (1/2) * (1/2) = 1/6 := by norm_num

/-- 全敗者ありで A が 2 勝 1 敗で優勝する確率 = 3 · (1/6) · (2/27) = 1/27。
    (D 全敗下で A は (1)(ii) と同じ状況、(1)(ii) の答え 2/27 を流用、対称性で 3 倍)。 -/
theorem A_2win_with_total_loss : 3 * ((1 : ℝ)/6) * (2/27) = 1/27 := by norm_num

/-- 全敗者なしで A が B 負けケースで 2 勝 1 敗優勝の対戦結果数 = 4。
    各対戦結果の確率 (1/3)(2/3)(2/3)(1/2)^3 = 1/54。
    A 優勝確率 (抽選 1/2) → 4 · (1/54) · (1/2) = 1/27。
    A 負け相手 B/C/D の 3 通り → 3 · (1/27) = 1/9。 -/
theorem A_2win_no_total_loss :
    3 * (4 * (((1 : ℝ)/3) * (2/3) * (2/3) * (1/2)^3) * (1/2)) = 1/9 := by norm_num

/-- A が 2 勝 1 敗で優勝する全確率 = 1/27 + 1/9 = 4/27。 -/
theorem A_2win_total : ((1 : ℝ)/27) + (1/9) = 4/27 := by norm_num

/-- A が 3 勝 0 敗の確率 = (2/3)^3 = 8/27。 -/
theorem A_3win : ((2 : ℝ)/3)^3 = 8/27 := by norm_num

/-- A の優勝確率 = 8/27 + 4/27 = 12/27 = 4/9。 -/
theorem A_total : ((8 : ℝ)/27) + (4/27) = 12/27 := by norm_num

end four_people

/-- 3 人と 4 人の優勝確率の比較: 14/27 - 12/27 = 2/27 > 0。
    すなわち 3 人の方が大きい (= 4 人は 3 人より 2/27 小さい)。 -/
theorem three_gt_four : ((14 : ℝ)/27) - (12/27) = 2/27 ∧ (0 : ℝ) < 2/27 := by
  refine ⟨?_, ?_⟩ <;> norm_num

end Common2026.Q4
